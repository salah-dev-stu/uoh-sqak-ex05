# Copy to .env (which is git-ignored) and fill in. NEVER commit real secrets (R11).

# Optional: only needed if you switch the primary model to the GATED Llama-3.1-8B
# alternative. The default primary (Qwen2.5-7B-Instruct) is ungated and needs no token.
HF_TOKEN=

# Optional: only needed if you fetch live API prices for the §5.5 economics comparison.
# The economics analysis works fully from config/economics.json without any key.
OPENAI_API_KEY=
